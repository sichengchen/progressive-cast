{
  "name": "@pgcast/pwa",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names client,api --prefix name \"pnpm dev:client\" \"pnpm dev:api\"",
    "dev:client": "node ./scripts/build-sw.mjs && vp dev",
    "dev:api": "tsx watch src/api/server.ts",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "node ./scripts/build-sw.mjs && vp build",
    "build:server": "vp pack",
    "check": "vp check",
    "cf:build": "pnpm build:client && pnpm cf:typegen",
    "cf:check": "pnpm cf:build && wrangler deploy --dry-run --config wrangler.jsonc",
    "cf:deploy": "pnpm cf:build && wrangler deploy --config wrangler.jsonc",
    "cf:dev": "pnpm cf:build && wrangler dev --config wrangler.jsonc",
    "cf:typegen": "wrangler types ./src/worker-configuration.d.ts --config wrangler.jsonc",
    "test": "vp test",
    "preview": "node dist/server/server.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.6",
    "@hono/node-server": "^1.19.1",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-toggle": "^1.1.9",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.87.4",
    "@tanstack/react-router": "^1.131.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.0.11",
    "dompurify": "^3.2.6",
    "hono": "^4.9.6",
    "iso-639-1": "^3.1.5",
    "lucide-react": "^0.525.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "rss-parser": "^3.13.0",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "@types/node": "^20.17.58",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5.8.3",
    "vite-plus": "^0.1.16",
    "wrangler": "^4.22.0"
  }
}
