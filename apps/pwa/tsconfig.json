{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["node"]
  },
  "include": [
    "index.html",
    "src/**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.mjs",
    "vite.config.ts"
  ]
}
